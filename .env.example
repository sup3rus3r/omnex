# ─────────────────────────────────────────────────────────────────────────────
# Omnex — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Drive Paths ───────────────────────────────────────────────────────────────
# Source: the drive or folder Omnex will index
# Destination: where Omnex stores its index, models, and binary chunks
OMNEX_SOURCE_PATH=/mnt/source_drive
OMNEX_DATA_PATH=/mnt/omnex_data

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=omnex

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: local | openai | anthropic
LLM_PROVIDER=local

# ── Local LLM — Ollama / LM Studio ───────────────────────────────────────────
# Ollama: http://localhost:11434
# LM Studio: http://localhost:1234/v1
LOCAL_LLM_HOST=http://localhost:11434
# Options: phi3:mini | gemma3:2b | llama3.2:3b | phi3:medium
LOCAL_LLM_MODEL=phi3:mini

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Used when LLM_PROVIDER=openai
OPENAI_API_KEY=
# Options: gpt-5.4 | gpt-5.4-mini | o3 | o4-mini
OPENAI_MODEL=gpt-5.4-mini

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Options: claude-sonnet-4-6 | claude-opus-4-6 | claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000

# ── Ingestion ─────────────────────────────────────────────────────────────────
# Number of parallel ingestion workers
INGEST_WORKERS=4
# Chunk size for binary files (bytes)
INGEST_CHUNK_SIZE=4194304

# ── ML / GPU ──────────────────────────────────────────────────────────────────
# Set to true if CUDA (NVIDIA) or ROCm (AMD) GPU is available
GPU_ENABLED=false
# CUDA device index (ignored if GPU_ENABLED=false)
CUDA_DEVICE=0

# ── LEANN Vector Index ────────────────────────────────────────────────────────
LEANN_INDEX_PATH=/mnt/omnex_data/leann

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Interface ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
